{
  "name": "paperpilot-extension",
  "version": "1.0.0",
  "description": "PaperPilot - 学术文献助手 Chrome Extension",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
